# ─────────────────────────────────────────────────────────────────────────
# FoodBank — production environment template
#
# Copy this file to `.env` on the production host and fill the marked
# values. NEVER commit the filled `.env` file. After populating, run:
#
#   php artisan key:generate           # if APP_KEY is empty
#   php artisan migrate --force        # apply schema (--force = no prompt)
#   php artisan db:seed --class=Database\\Seeders\\RoleSeeder       # required
#   php artisan db:seed --class=Database\\Seeders\\SettingsSeeder   # required
#   php artisan storage:link
#   php artisan config:cache
#   php artisan route:cache
#   php artisan view:cache
#   php artisan event:cache
#
# Then create your first admin user manually (do NOT run AdminUserSeeder
# without setting ADMIN_SEED_PASSWORD below — that seeder refuses to run
# in production without it).
# ─────────────────────────────────────────────────────────────────────────

APP_NAME="Food Bank"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Bcrypt cost. 12 is fine for a production CPU.
BCRYPT_ROUNDS=12

# ─── Logging ───────────────────────────────────────────────────────────
# `daily` rotates to a new file each day; logs older than 14 days are
# pruned automatically. `single` keeps everything in one file forever.
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ─── Database ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=foodbank
DB_USERNAME=foodbank_app
DB_PASSWORD=

# ─── Sessions / Cookies ────────────────────────────────────────────────
# `database` driver requires the `sessions` table (already migrated).
# SESSION_SECURE_COOKIE=true REQUIRES TLS — without HTTPS the cookie will
# never be sent and users won't stay logged in. Set false ONLY if you've
# deliberately decided to run without TLS.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ─── Filesystem / Queue / Cache / Broadcast ────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=foodbank_

# ─── Mail ──────────────────────────────────────────────────────────────
# Public registrations + reviews don't currently send mail, but org-side
# password reset uses the configured mailer. Set up a real SMTP / SES /
# Mailgun / Postmark account before relying on it.
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@your-domain.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Admin seeder password ─────────────────────────────────────────────
# Required if you run AdminUserSeeder in production. Without this set,
# the seeder will throw rather than silently install a known credential.
# Generate once, store in your secrets manager, then unset:
#   ADMIN_SEED_PASSWORD=$(openssl rand -base64 24)
ADMIN_SEED_PASSWORD=

# ─── AWS (optional, for S3-backed media uploads) ───────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Trusted proxies (set when behind a load balancer / reverse proxy) ─
# Uncomment and list the proxy IPs (comma-separated). `*` trusts all
# proxies — only use that when the LB is on a private network and the
# app server is not directly reachable from the public internet.
# TRUSTED_PROXIES=*
